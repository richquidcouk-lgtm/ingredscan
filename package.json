{
  "name": "ingredscan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "import:off": "tsx scripts/importProducts.ts --source=openfoodfacts",
    "import:off:resume": "tsx scripts/importProducts.ts --source=openfoodfacts --resume",
    "import:fsa": "tsx scripts/importProducts.ts --source=fsa",
    "import:usda": "tsx scripts/importProducts.ts --source=usda",
    "import:tesco": "tsx scripts/importProducts.ts --source=tesco",
    "import:sainsburys": "tsx scripts/importProducts.ts --source=sainsburys",
    "import:asda": "tsx scripts/importProducts.ts --source=asda",
    "import:waitrose": "tsx scripts/importProducts.ts --source=waitrose",
    "import:supermarkets": "tsx scripts/importProducts.ts --source=tesco && tsx scripts/importProducts.ts --source=sainsburys && tsx scripts/importProducts.ts --source=asda && tsx scripts/importProducts.ts --source=waitrose",
    "import:all": "tsx scripts/importProducts.ts --source=all",
    "import:dry-run": "tsx scripts/importProducts.ts --source=openfoodfacts --dry-run --limit=100"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "rotating-file-stream": "^3.2.9",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "zod": "^4.3.6"
  }
}
