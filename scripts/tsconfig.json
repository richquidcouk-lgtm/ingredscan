{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["./**/*.ts", "../data/**/*.json"],
  "exclude": ["node_modules", "dist"]
}
